{
    "name": "r4kib/pachy",
    "description": "Minimalist Coding Agent Written in PHP",
    "keywords": ["agent", "coding", "ai", "console", "cli"],
    "homepage": "https://github.com/r4kib/pachy",
    "type": "library",
    "license": "GPL-3.0-or-later",
    "support": {
        "issues": "https://github.com/r4kib/pachy/issues",
        "source": "https://github.com/r4kib/pachy"
    },
    "authors": [
        {
            "name": "Rakib Hasan",
            "email": "rakibatwork24@gmail.com"
        }
    ],
    "require": {
        "php": "^8.5"
    },
    "require-dev": {
        "greph/greph": "^v0.2",
        "laravel-zero/framework": "^12.1",
        "neuron-core/neuron-ai": "^3.4",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "pestphp/pest": "^4.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["builds/pachy"]
}
