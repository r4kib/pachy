{
    "branches": ["main"],
    "tagFormat": "v${version}",
    "plugins": [
        "@semantic-release/commit-analyzer",
        "@semantic-release/release-notes-generator",

        [
            "@semantic-release/exec",
            {
                "prepareCmd": "php pachy app:build --build-version=${nextRelease.version} --no-interaction && git add -f builds/pachy"
            }
        ],

        [
            "@semantic-release/git",
            {
                "assets": ["builds/pachy"],
                "message": "chore(build): release ${nextRelease.version} [skip ci]"
            }
        ],

        "@semantic-release/github"
    ]
}
