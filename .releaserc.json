{
    "branches": ["main"],
    "tagFormat": "v${version}",
    "plugins": [
        "@semantic-release/commit-analyzer",
        "@semantic-release/release-notes-generator",

        [
            "@semantic-release/exec",
            {
                "prepareCmd": "php pachy app:build --build-version=${nextRelease.version} && echo ${nextRelease.version} > builds/version.txt && git add builds/pachy builds/version.txt"
            }
        ],

        [
            "@semantic-release/git",
            {
                "assets": ["builds/pachy"],
                "message": "chore(build): release ${nextRelease.version} [skip ci]"
            }
        ],

        "@semantic-release/github"
    ]
}
